 #[cfg(feature = "std")]
 impl std::error::Error for ClientError {}
 
+// ShellDeck patch: IBus/XIM sometimes sends raw Latin-1 bytes (e.g. 0xE7 = "ç")
+// as unescaped compound text. Upstream `.expect("Encoding Error")` panicked the
+// whole GPUI app; fall back to Latin-1 instead of crashing.
+fn compound_text_to_utf8_or_latin1(bytes: &[u8]) -> String {
+    match xim_ctext::compound_text_to_utf8(bytes) {
+        Ok(text) => text,
+        Err(err) => {
+            log::warn!(
+                "XIM compound text decode failed ({err}); using Latin-1 fallback"
+            );
+            bytes
+                .iter()
+                .map(|&b| char::from_u32(u32::from(b)).unwrap_or('\u{FFFD}'))
+                .collect()
+        }
+    }
+}
